{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "preinstall": "node -e \"const ua=process.env.npm_config_user_agent||''; if(!ua.startsWith('pnpm/')){console.error('Use pnpm instead'); process.exit(1)}\"",
    "dev": "corepack pnpm --filter @workspace/koi run dev",
    "dev:api": "corepack pnpm --filter @workspace/api-server run dev",
    "build:koi": "corepack pnpm --filter @workspace/koi run build",
    "typecheck:koi": "corepack pnpm --filter @workspace/koi run typecheck",
    "build": "corepack pnpm run typecheck && corepack pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "corepack pnpm run typecheck:libs && corepack pnpm -r --filter @workspace/koi --filter @workspace/api-server --filter @workspace/scripts --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
