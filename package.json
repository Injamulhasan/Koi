{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "preinstall": "node -e \"const ua=process.env.npm_config_user_agent||''; if(!ua.startsWith('pnpm/')){console.error('Use pnpm instead'); process.exit(1)}\"",
    "dev": "pnpm --filter podcast-planner-frontend --filter podcast-planner-backend --parallel dev",
    "dev:frontend": "pnpm --filter podcast-planner-frontend run dev",
    "dev:backend": "pnpm --filter podcast-planner-backend run dev",
    "build": "pnpm --filter podcast-planner-frontend run build",
    "start": "pnpm --filter podcast-planner-backend start"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
